{
  "name": "dataviz-mcp",
  "version": "0.2.0",
  "description": "A Model Context Protocol server for data visualization",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "mcp-app",
    "data-visualization",
    "dataviz",
    "d3",
    "charts",
    "fastmcp"
  ],
  "author": "Brandon Burrus <brandon@burrus.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brandonburrus/dataviz-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/brandonburrus/dataviz-mcp/issues"
  },
  "homepage": "https://github.com/brandonburrus/dataviz-mcp#readme",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "dataviz-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm build:server && pnpm build:app",
    "build:server": "tsup",
    "build:app": "vite build",
    "dev": "pnpm build:app && tsx src/index.ts",
    "typecheck": "tsc --noEmit && tsc -p src/app/tsconfig.json --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "d3": "^7.9.0",
    "fastmcp": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.6",
    "happy-dom": "^20.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,json,md,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
